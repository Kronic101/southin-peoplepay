{
  "name": "southin-peoplepay",
  "version": "0.1.0",
  "private": true,
  "description": "Southin PeoplePay HR and Payroll Management System",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css}\"",
    "db:generate": "pnpm --filter @southin/api prisma:generate",
    "db:push": "pnpm --filter @southin/api prisma:push",
    "db:seed": "pnpm --filter @southin/api prisma:seed"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.0"
}
