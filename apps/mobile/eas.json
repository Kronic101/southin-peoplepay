{
  "cli": {
    "version": ">= 20.4.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://southinapi-production.up.railway.app/api",
        "EXPO_PUBLIC_ALLOW_DEV_LOGIN": "EXPO_PUBLIC_API_URL","https://southinapi-production.up.railway.app/api":"true"
        
      }
    },
    "production": {
      "distribution": "store",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://southinapi-production.up.railway.app/api",
        "EXPO_PUBLIC_ALLOW_DEV_LOGIN": "false"
      }
    }
  }
}