generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  users       UserRole[]
}

model User {
  id              String     @id @default(uuid())
  email           String?    @unique
  displayName     String
  microsoftUserId String?    @unique
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  roles           UserRole[]
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, roleId])
}

model Department {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
}

model JobTitle {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
}

model Site {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
}

model EmploymentType {
  id          String                     @id @default(uuid())
  name        String                     @unique
  description String?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  employees   Employee[]
  templates   ServiceConditionTemplate[]
}

model Employee {
  id                String                     @id @default(uuid())
  employeeNumber    String                     @unique
  firstName         String
  middleName        String?
  lastName          String
  gender            String?
  dateOfBirth       DateTime?
  nrcNumber         String?
  email             String?
  phone             String?
  departmentId      String?
  jobTitleId        String?
  siteId            String?
  employmentTypeId  String?
  supervisorId      String?
  startDate         DateTime?
  endDate           DateTime?
  status            EmployeeStatus             @default(DRAFT)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  department        Department?                @relation(fields: [departmentId], references: [id])
  employmentType    EmploymentType?            @relation(fields: [employmentTypeId], references: [id])
  jobTitle          JobTitle?                  @relation(fields: [jobTitleId], references: [id])
  site              Site?                      @relation(fields: [siteId], references: [id])
  supervisor        Employee?                  @relation("EmployeeSupervisor", fields: [supervisorId], references: [id])
  directReports     Employee[]                 @relation("EmployeeSupervisor")
  bankAuditLogs     EmployeeBankAuditLog[]

  bankAccounts      EmployeeBankAccount[]
  bankName              String?
  bankBranch            String?
  bankAccountNumber     String?
  bankAccountName       String?
  bankSortCode          String?
  bankDetailsStatus     String?   @default("PENDING_VALIDATION")
  bankDetailsReviewedBy String?
  bankDetailsReviewedAt DateTime?
  bankDetailsNotes      String?
  
  contracts         EmployeeContract[]
  portalAccount     EmployeePortalAccount?
  serviceConditions EmployeeServiceCondition[]
  paymentBatchItems PaymentBatchItem[]
  statutoryDetails  EmployeeStatutoryDetails?
  payrollRuns       PayrollRunEmployee[]
  payslips          Payslip[]

  leaveRequests     LeaveRequest[]
}

model EmployeePortalAccount {
  id             String    @id @default(uuid())
  employeeId     String    @unique
  employeeNumber String    @unique
  pinHash        String
  mustChangePin  Boolean   @default(true)
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  employee       Employee  @relation(fields: [employeeId], references: [id])
}

model EmployeeStatutoryDetails {
  id              String   @id @default(uuid())
  employeeId      String   @unique
  tpin            String?
  napsaNumber     String?
  nhimaNumber     String?
  payeApplicable  Boolean  @default(true)
  napsaApplicable Boolean  @default(true)
  nhimaApplicable Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  employee        Employee @relation(fields: [employeeId], references: [id])
}

model EmployeeBankAccount {
  id             String         @id @default(uuid())
  employeeId     String
  bankName       String
  branchName     String?
  accountNumber  String
  accountName    String
  isPrimary      Boolean        @default(false)
  approvalStatus ApprovalStatus @default(PENDING)
  effectiveFrom  DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  employee       Employee       @relation(fields: [employeeId], references: [id])
  auditLogs      EmployeeBankAuditLog[]
}

model EmployeeBankAuditLog {
  id            String   @id @default(uuid())
  employeeId    String
  bankAccountId String?
  action        String
  previousStatus String?
  newStatus      String?
  changedBy     String
  notes         String?
  snapshot      Json?
  createdAt     DateTime @default(now())

  employee    Employee             @relation(fields: [employeeId], references: [id])
  bankAccount EmployeeBankAccount? @relation(fields: [bankAccountId], references: [id])

  @@index([employeeId])
  @@index([bankAccountId])
  @@index([action])
  @@index([createdAt])
}

model ContractType {
  id          String             @id @default(uuid())
  name        String             @unique
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  contracts   EmployeeContract[]
}

model EmployeeContract {
  id             String        @id @default(uuid())
  employeeId     String
  contractTypeId String?
  startDate      DateTime
  endDate        DateTime?
  probationEnd   DateTime?
  noticePeriod   String?
  status         String        @default("ACTIVE")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  contractNumber String?       @unique
  contractType   ContractType? @relation(fields: [contractTypeId], references: [id])
  employee       Employee      @relation(fields: [employeeId], references: [id])
}

model ServiceConditionTemplate {
  id               String                      @id @default(uuid())
  name             String                      @unique
  description      String?
  employmentTypeId String?
  isActive         Boolean                     @default(true)
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  assignments      EmployeeServiceCondition[]
  components       ServiceConditionComponent[]
  employmentType   EmploymentType?             @relation(fields: [employmentTypeId], references: [id])
}

model ServiceConditionComponent {
  id                String                   @id @default(uuid())
  templateId        String
  componentName     String
  componentType     String
  calculationMethod String
  amount            Decimal?                 @db.Decimal(14, 2)
  percentage        Decimal?                 @db.Decimal(8, 4)
  frequency         String?
  taxable           Boolean                  @default(true)
  napsaPensionable  Boolean                  @default(false)
  nhimaApplicable   Boolean                  @default(false)
  includedInGross   Boolean                  @default(true)
  requiresApproval  Boolean                  @default(false)
  effectiveFrom     DateTime?
  effectiveTo       DateTime?
  isActive          Boolean                  @default(true)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  template          ServiceConditionTemplate @relation(fields: [templateId], references: [id])
}

model EmployeeServiceCondition {
  id            String                   @id @default(uuid())
  employeeId    String
  templateId    String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  status        ApprovalStatus           @default(PENDING)
  assignedBy    String?
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  employee      Employee                 @relation(fields: [employeeId], references: [id])
  template      ServiceConditionTemplate @relation(fields: [templateId], references: [id])
}

model PayrollPeriod {
  id         String       @id @default(uuid())
  periodName String
  startDate  DateTime
  endDate    DateTime
  payDate    DateTime?
  status     String       @default("OPEN")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  runs       PayrollRun[]
  payslips   Payslip[]
}

model PayrollRun {
  id                 String               @id @default(uuid())
  payrollPeriodId    String
  runName            String
  runType            PayrollRunType       @default(MONTHLY)
  status             PayrollRunStatus     @default(OPEN)
  preparedBy         String?
  submittedAt        DateTime?
  hrReviewedBy       String?
  financeReviewedBy  String?
  directorApprovedBy String?
  lockedAt           DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  approvals          PayrollApproval[]
  paymentBatches     PaymentBatch[]
  payrollPeriod      PayrollPeriod        @relation(fields: [payrollPeriodId], references: [id])
  employees          PayrollRunEmployee[]
}

model PayrollRunEmployee {
  id              String             @id @default(uuid())
  payrollRunId    String
  employeeId      String
  grossPay        Decimal            @default(0) @db.Decimal(14, 2)
  totalDeductions Decimal            @default(0) @db.Decimal(14, 2)
  netPay          Decimal            @default(0) @db.Decimal(14, 2)
  employerCost    Decimal            @default(0) @db.Decimal(14, 2)
  status          String             @default("DRAFT")
  calculatedAt    DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deductions      PayrollDeduction[]
  paymentBatchItems PaymentBatchItem[]
  earnings        PayrollEarning[]
  employee        Employee           @relation(fields: [employeeId], references: [id])
  payrollRun      PayrollRun         @relation(fields: [payrollRunId], references: [id])
  payslip         Payslip?
}

model PayrollEarning {
  id                   String             @id @default(uuid())
  payrollRunEmployeeId String
  earningType          String
  description          String?
  amount               Decimal            @db.Decimal(14, 2)
  taxable              Boolean            @default(true)
  napsaPensionable     Boolean            @default(false)
  nhimaApplicable      Boolean            @default(false)
  source               String?
  createdAt            DateTime           @default(now())
  payrollRunEmployee   PayrollRunEmployee @relation(fields: [payrollRunEmployeeId], references: [id])
}

model PayrollDeduction {
  id                   String             @id @default(uuid())
  payrollRunEmployeeId String
  deductionType        String
  description          String?
  amount               Decimal            @db.Decimal(14, 2)
  source               String?
  createdAt            DateTime           @default(now())
  payrollRunEmployee   PayrollRunEmployee @relation(fields: [payrollRunEmployeeId], references: [id])
}

model PayrollApproval {
  id            String         @id @default(uuid())
  payrollRunId  String
  approvalStage String
  approverRole  String
  approverId    String?
  status        ApprovalStatus @default(PENDING)
  comments      String?
  approvedAt    DateTime?
  createdAt     DateTime       @default(now())
  payrollRun    PayrollRun     @relation(fields: [payrollRunId], references: [id])
}

model PaymentBatch {
  id              String             @id @default(uuid())
  payrollRunId    String
  batchName       String
  status          String             @default("DRAFT")
  totalEmployees  Int                @default(0)
  totalNetPay     Decimal            @default(0) @db.Decimal(18, 2)
  preparedBy      String?
  preparedAt      DateTime?
  reviewedBy      String?
  reviewedAt      DateTime?
  approvedBy      String?
  approvedAt      DateTime?
  evidenceNotes   String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  payrollRun      PayrollRun         @relation(fields: [payrollRunId], references: [id])
  items           PaymentBatchItem[]

  @@index([payrollRunId])
  @@index([status])
}

model PaymentBatchItem {
  id                   String   @id @default(uuid())
  paymentBatchId        String
  payrollRunEmployeeId  String
  employeeId            String
  employeeNumber        String
  employeeName          String
  department            String?
  netPay                Decimal  @default(0) @db.Decimal(18, 2)

  bankName              String?
  bankBranch            String?
  bankAccountNumber     String?
  bankAccountName       String?
  bankDetailsStatus     String   @default("PENDING_VALIDATION")

  paymentStatus         String   @default("PENDING")
  validationNotes       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  paymentBatch          PaymentBatch        @relation(fields: [paymentBatchId], references: [id])
  payrollRunEmployee    PayrollRunEmployee @relation(fields: [payrollRunEmployeeId], references: [id])
  employee              Employee           @relation(fields: [employeeId], references: [id])

  @@index([paymentBatchId])
  @@index([employeeId])
  @@index([paymentStatus])
}

model Payslip {
  id                   String             @id @default(uuid())
  payrollRunEmployeeId String             @unique
  employeeId           String
  payrollPeriodId      String
  generatedAt          DateTime           @default(now())
  createdAt            DateTime           @default(now())
  employerCost         Decimal            @db.Decimal(14, 2)
  grossPay             Decimal            @db.Decimal(14, 2)
  netPay               Decimal            @db.Decimal(14, 2)
  status               String             @default("GENERATED")
  totalDeductions      Decimal            @db.Decimal(14, 2)
  updatedAt            DateTime           @updatedAt
  employee             Employee           @relation(fields: [employeeId], references: [id])
  payrollPeriod        PayrollPeriod      @relation(fields: [payrollPeriodId], references: [id])
  payrollRunEmployee   PayrollRunEmployee @relation(fields: [payrollRunEmployeeId], references: [id])
}

model TaxYear {
  id        String     @id @default(uuid())
  name      String     @unique
  startDate DateTime
  endDate   DateTime
  isActive  Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  payeBands PayeBand[]
}

model PayeBand {
  id         String   @id @default(uuid())
  taxYearId  String
  lowerBound Decimal  @db.Decimal(14, 2)
  upperBound Decimal? @db.Decimal(14, 2)
  rate       Decimal  @db.Decimal(8, 4)
  createdAt  DateTime @default(now())
  taxYear    TaxYear  @relation(fields: [taxYearId], references: [id])
}

model NapsaRate {
  id             String    @id @default(uuid())
  name           String
  employeeRate   Decimal   @db.Decimal(8, 4)
  employerRate   Decimal   @db.Decimal(8, 4)
  monthlyCeiling Decimal?  @db.Decimal(14, 2)
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  status         String    @default("DRAFT")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model NhimaRate {
  id              String    @id @default(uuid())
  name            String
  employeeRate    Decimal   @db.Decimal(8, 4)
  employerRate    Decimal   @db.Decimal(8, 4)
  calculationBase String    @default("CONFIGURABLE")
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  status          String    @default("DRAFT")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model SdlRate {
  id              String    @id @default(uuid())
  name            String
  employerRate    Decimal   @db.Decimal(8, 4)
  calculationBase String    @default("GROSS_EMOLUMENTS")
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  status          String    @default("DRAFT")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  beforeJson  Json?
  afterJson   Json?
  reason      String?
  createdAt   DateTime @default(now())
}

model DashboardSnapshot {
  id                    String   @id @default(uuid())
  snapshotType          String
  payload               Json
  createdAt             DateTime @default(now())
  publishedToSharePoint Boolean  @default(false)
}

model SharePointPublishLog {
  id          String   @id @default(uuid())
  publishType String
  status      String
  targetPath  String?
  message     String?
  createdAt   DateTime @default(now())
}

model SharePointExportLog {
  id                String                 @id @default(uuid())
  targetSite        String
  targetPage        String?
  targetLibrary     String?
  payloadEndpoint   String
  payloadType       String?
  confidentiality   String?
  requestedBy       String?
  graphEnabled      Boolean                @default(false)
  graphStatus       SharePointExportStatus @default(DISABLED_DEV_MODE)
  requestPayload    Json?
  responsePayload   Json?
  errorMessage      String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
}

model LeaveRequest {
  id              String             @id @default(uuid())
  employeeId      String
  employee        Employee           @relation(fields: [employeeId], references: [id])

  leaveType       LeaveType
  startDate       DateTime
  endDate         DateTime
  totalDays       Int
  reason          String?

  supervisorName  String?
  supervisorEmail String

  status          LeaveRequestStatus @default(PENDING_SUPERVISOR)

  submittedAt     DateTime           @default(now())
  reviewedAt      DateTime?
  reviewedBy      String?
  reviewComment   String?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([supervisorEmail])
}

model OrgDepartment {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  positions OrgPosition[]
  approvalMatrixRules ApprovalMatrixRule[]

  @@map("org_departments")
}

model OrgRole {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  isStaffRole Boolean  @default(true)
  isActive    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  positions OrgPosition[]

  @@map("org_roles")
}

model OrgPosition {
  id           String  @id @default(uuid())
  title        String
  positionCode String? @unique
  site         String?
  branch       String?
  isHod        Boolean @default(false)
  isActive     Boolean @default(true)

  departmentId String?
  department   OrgDepartment? @relation(fields: [departmentId], references: [id])

  roleId String?
  role   OrgRole? @relation(fields: [roleId], references: [id])

  reportsToPositionId String?
  reportsToPosition   OrgPosition?  @relation("PositionReportingLine", fields: [reportsToPositionId], references: [id])
  directReports       OrgPosition[] @relation("PositionReportingLine")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("org_positions")
}

model ApprovalMatrixRule {
  id           String               @id @default(uuid())
  module       OperationsModule
  workflowType ApprovalWorkflowType

  name        String
  description String?

  departmentId String?
  department   OrgDepartment? @relation(fields: [departmentId], references: [id])

  site        String?
  branch      String?

  minAmount   Decimal? @db.Decimal(18, 2)
  maxAmount   Decimal? @db.Decimal(18, 2)

  requiresFinance Boolean @default(false)
  requiresDirector Boolean @default(false)

  // JSON approval steps example:
  // [
  //   { "sequence": 1, "role": "LINE_MANAGER", "required": true },
  //   { "sequence": 2, "role": "HOD", "required": true },
  //   { "sequence": 3, "role": "FINANCE_MANAGER", "required": true }
  // ]
  approvalSteps Json

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  approvalRequests ApprovalRequest[]

  @@index([module, workflowType])
  @@map("approval_matrix_rules")
}

model ApprovalRequest {
  id           String                @id @default(uuid())
  module       OperationsModule
  workflowType ApprovalWorkflowType

  requestTitle       String
  requestReference   String?
  requestDescription String?

  requesterEmployeeId String?
  requesterName       String?
  requesterRole       String?
  requesterDepartment String?
  requesterSite       String?

  amount Decimal? @db.Decimal(18, 2)

  sourceEntityType String?
  sourceEntityId   String?

  status ApprovalRequestStatus @default(SUBMITTED)
  currentStep       Int       @default(1)

  approvalMatrixRuleId String?
  approvalMatrixRule   ApprovalMatrixRule? @relation(fields: [approvalMatrixRuleId], references: [id])

  payload Json?

  submittedAt DateTime @default(now())
  closedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  decisions ApprovalDecision[]

  @@index([module, workflowType])
  @@index([sourceEntityType, sourceEntityId])
  @@map("approval_requests")
}

model ApprovalDecision {
  id String @id @default(uuid())

  approvalRequestId String
  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)

  sequence Int
  role     ApprovalStepRole

  approverEmployeeId String?
  approverName       String?
  approverEmail      String?

  status   ApprovalDecisionStatus @default(PENDING)
  comments String?

  decidedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([approvalRequestId])
  @@map("approval_decisions")
}

model FinanceReportExportLog {
  id              String                    @id @default(uuid())

  reportType      FinanceReportType
  exportFormat    FinanceExportFormat       @default(JSON)
  status          FinanceReportExportStatus @default(GENERATED)

  requestedBy     String?
  requestedByEmail String?

  filterPayload   Json?
  resultSummary   Json?
  fileName        String?
  errorMessage    String?

  createdAt       DateTime                  @default(now())

  @@index([reportType])
  @@index([exportFormat])
  @@index([createdAt])
  @@map("finance_report_export_logs")
}

model FinanceExpense {
  id              String               @id @default(uuid())
  expenseNo       String               @unique

  category        String
  description     String
  amount          Decimal              @db.Decimal(18, 2)
  department      String?
  site            String?
  payee           String?
  requestedBy     String?
  requestedByEmail String?

  status          FinanceExpenseStatus @default(SUBMITTED)
  evidenceStatus  FinanceEvidenceStatus @default(REQUIRED)

  approvalRequestId String?
  paidBy          String?
  paidAt          DateTime?
  paymentReference String?

  financeComment  String?
  payload          Json?

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([status])
  @@index([department])
  @@index([site])
  @@map("finance_expenses")
}

model FinancePaymentEvidence {
  id              String   @id @default(uuid())
  expenseId       String?
  paymentBatchId  String?
  procurementId   String?

  evidenceType    String
  title           String
  status          String   @default("REQUIRED")
  documentId      String?
  notes           String?

  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([expenseId])
  @@index([paymentBatchId])
  @@index([procurementId])
  @@map("finance_payment_evidence")
}

model HubDocument {
  id              String                    @id @default(uuid())
  module          OperationsModule
  sourceEntityType String?
  sourceEntityId   String?

  title           String
  documentType    String
  fileName        String?
  mimeType        String?
  fileSizeBytes   Int?
  storageProvider String                    @default("LOCAL_DEV")
  storagePath     String?
  sharePointUrl   String?

  status          HubDocumentStatus         @default(DRAFT)
  confidentiality HubDocumentConfidentiality @default(INTERNAL)

  uploadedBy      String?
  approvedBy      String?
  approvedAt      DateTime?

  metadata        Json?

  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([module])
  @@index([sourceEntityType, sourceEntityId])
  @@map("hub_documents")
}

model ProcurementRequest {
  id                String                   @id @default(uuid())
  requisitionNo     String                   @unique

  department        String
  site              String?
  requestedBy       String?
  supplierName      String?
  description       String
  amount            Decimal                  @db.Decimal(18, 2)

  procurementStage  String                   @default("REQUISITION_SUBMITTED")
  financeStage      String                   @default("NOT_REVIEWED")
  status            ProcurementRequestStatus @default(SUBMITTED)

  invoiceStatus     String                   @default("PENDING")
  paymentStatus     String                   @default("NOT_PAID")
  proofOfPaymentStatus String                @default("NOT_UPLOADED")

  purchaseOrderNo   String?
  invoiceNo         String?
  goodsReceivedNote String?

  approvalRequestId String?
  payload           Json?

  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([status])
  @@index([department])
  @@index([site])
  @@map("procurement_requests")
}

model HubAsset {
  id              String        @id @default(uuid())
  assetNo         String        @unique
  assetTag        String?
  category        AssetCategory
  name            String
  description     String?

  department      String?
  site            String?
  location        String?

  serialNumber    String?
  purchaseDate    DateTime?
  purchaseValue   Decimal?      @db.Decimal(18, 2)
  currentValue    Decimal?      @db.Decimal(18, 2)

  supplierName    String?
  procurementRequestId String?

  status          AssetStatus   @default(ACTIVE)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  movements       HubAssetMovement[]
  inspections     HubAssetInspection[]
  qrTags          AssetQrTag[]

  @@index([category])
  @@index([status])
  @@index([site])
  @@map("hub_assets")
}

model HubAssetMovement {
