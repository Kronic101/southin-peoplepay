  locationId      String
  location        StockLocation @relation(fields: [locationId], references: [id])

  quantityOnHand  Decimal       @default(0) @db.Decimal(18, 2)
  quantityIssued  Decimal       @default(0) @db.Decimal(18, 2)
  quantityDamaged Decimal       @default(0) @db.Decimal(18, 2)
  quantityLost    Decimal       @default(0) @db.Decimal(18, 2)

  updatedAt       DateTime      @updatedAt

  @@unique([stockItemId, locationId])
  @@index([locationId])
  @@map("stock_balances")
}

model StockMovement {
  id                String              @id @default(uuid())
  movementNo        String              @unique

  movementType      StockMovementType
  status            StockMovementStatus @default(DRAFT)

  fromLocationId    String?
  fromLocation      StockLocation?      @relation("StockMovementFromLocation", fields: [fromLocationId], references: [id])

  toLocationId      String?
  toLocation        StockLocation?      @relation("StockMovementToLocation", fields: [toLocationId], references: [id])

  requestedBy       String?
  requestedByEmail  String?
  department        String?
  site              String?
  projectCode       String?

  reason            String?
  referenceType     String?
  referenceId       String?

  approvalRequestId String?

  submittedAt       DateTime?
  approvedBy        String?
  approvedAt        DateTime?
  postedBy          String?
  postedAt          DateTime?

