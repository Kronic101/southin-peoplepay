  @@index([movementType])
  @@index([status])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@map("stock_movements")
}

model StockMovementLine {
  id              String        @id @default(uuid())

  movementId      String
  movement        StockMovement @relation(fields: [movementId], references: [id], onDelete: Cascade)

  stockItemId     String
  stockItem       StockItem     @relation(fields: [stockItemId], references: [id])

  quantity        Decimal       @db.Decimal(18, 2)
  unitCost        Decimal?      @db.Decimal(18, 2)
  totalCost       Decimal?      @db.Decimal(18, 2)

  qrTagId         String?
  qrTag           AssetQrTag?   @relation(fields: [qrTagId], references: [id])

  notes           String?

  createdAt       DateTime      @default(now())

  @@index([movementId])
  @@index([stockItemId])
  @@index([qrTagId])
  @@map("stock_movement_lines")
}

model AssetQrTag {
  id              String            @id @default(uuid())
  tagCode         String            @unique
  qrPayload       String?
  barcodeValue    String?

