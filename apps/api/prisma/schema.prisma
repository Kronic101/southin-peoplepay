  returnedAt       DateTime?
  returnedBy       String?

  conditionOut String?
  conditionIn  String?
  returnNotes  String?

  approvalRequestId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scaffoldComponent ScaffoldComponent? @relation(fields: [scaffoldComponentId], references: [id])
  stockItem         StockItem?         @relation(fields: [stockItemId], references: [id])
  qrTag             AssetQrTag?        @relation(fields: [qrTagId], references: [id])
  issuedToLocation  StockLocation?     @relation(fields: [issuedToLocationId], references: [id])
  financeExpense    FinanceExpense?    @relation(fields: [financeExpenseId], references: [id])

  @@index([scaffoldComponentId])
  @@index([stockItemId])
  @@index([qrTagId])
  @@index([movementId])
  @@index([issuedToLocationId])
  @@index([financeExpenseId])
  @@index([status])
  @@index([issuedToSite])
  @@map("scaffold_deployments")
}

model ScaffoldInspection {
  id           String  @id @default(uuid())
  inspectionNo String? @unique

  scaffoldComponentId String?
  scaffoldComponent   ScaffoldComponent? @relation(fields: [scaffoldComponentId], references: [id])

  qrTagId String?
  qrTag   AssetQrTag? @relation(fields: [qrTagId], references: [id])

  inspectionType   String @default("GENERAL")
  inspectionStatus String @default("OPEN")

  inspectionDate DateTime @default(now())
  inspectedAt    DateTime @default(now())
  inspectedBy    String?

  site     String?
  location String?

  conditionStatus  String?
  findings         String?
  actionRequired   String?
  correctiveAction String?
  isSafeForUse     Boolean @default(true)

  defectsFound       Boolean   @default(false)
  defectNotes        String?
  nextInspectionDate DateTime?

  evidenceDocumentId String?
  approvalRequestId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scaffoldComponentId])
  @@index([qrTagId])
  @@index([inspectionStatus])
  @@index([inspectedAt])
  @@map("scaffold_inspections")
}

model AssetQrTag {
  id           String  @id @default(uuid())
  tagCode      String  @unique
  qrPayload    String?
  barcodeValue String?

  stockItemId String?
  stockItem   StockItem? @relation(fields: [stockItemId], references: [id])

  assetId String?
  asset   HubAsset? @relation(fields: [assetId], references: [id])

  scaffoldComponentId String?
  scaffoldComponent   ScaffoldComponent? @relation(fields: [scaffoldComponentId], references: [id])

  assignedLocationId String?
  assignedLocation   StockLocation? @relation("QrTagAssignedLocation", fields: [assignedLocationId], references: [id])

  status ScaffoldTagStatus @default(AVAILABLE)

  lastScannedAt DateTime?
  lastScannedBy String?
  lastScanSite  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movementLines       StockMovementLine[]
  custodyAssignments  AssetCustodyAssignment[]
  scaffoldDeployments ScaffoldDeployment[]
  scaffoldInspections ScaffoldInspection[]

  @@index([tagCode])
  @@index([assetId])
  @@index([stockItemId])
  @@index([assignedLocationId])
  @@map("asset_qr_tags")
}

model ScaffoldComponent {
  id          String @id @default(uuid())
  componentNo String @unique

  componentType ScaffoldComponentType
  description   String?

  stockItemId String?
  stockItem   StockItem? @relation("StockItemScaffoldComponents", fields: [stockItemId], references: [id])

  currentSite     String?
  currentLocation String?

  conditionStatus String            @default("GOOD")
  tagStatus       ScaffoldTagStatus @default(AVAILABLE)

  purchaseDate  DateTime?
  purchaseValue Decimal?  @db.Decimal(18, 2)

  lastInspectionDate DateTime?
  nextInspectionDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qrTags      AssetQrTag[]
  deployments ScaffoldDeployment[]
  inspections ScaffoldInspection[]

  @@index([componentType])
  @@index([tagStatus])
  @@index([currentSite])
  @@map("scaffold_components")
}

model FleetWorkshopJob {
  id        String @id @default(uuid())
  jobCardNo String @unique

  vehicleId String
  vehicle   FleetVehicle @relation(fields: [vehicleId], references: [id])

  defectId String?
  defect   FleetDefect? @relation(fields: [defectId], references: [id])

  jobType  WorkshopJobType
  priority WorkshopJobPriority @default(MEDIUM)
  status   WorkshopJobStatus   @default(OPEN)

  title       String
  description String?
  diagnosis   String?
  workDone    String?

  openedBy   String?
  assignedTo String?
  approvedBy String?
  releasedBy String?

  openedAt    DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  approvedAt  DateTime?
  releasedAt  DateTime?
  closedAt    DateTime?

  odometerIn  Decimal? @db.Decimal(18, 2)
  odometerOut Decimal? @db.Decimal(18, 2)

  labourCost Decimal? @db.Decimal(18, 2)
  partsCost  Decimal? @db.Decimal(18, 2)
  totalCost  Decimal? @db.Decimal(18, 2)

  approvalRequestId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parts              FleetWorkshopPart[]
  labourLines        FleetWorkshopLabour[]
  stockMovements     StockMovement[]
  stockLedgerEntries StockLedger[]

  @@index([vehicleId])
  @@index([defectId])
  @@index([status])
  @@map("fleet_workshop_jobs")
}

model FleetWorkshopPart {
  id String @id @default(uuid())

  workshopJobId String
  workshopJob   FleetWorkshopJob @relation(fields: [workshopJobId], references: [id], onDelete: Cascade)

  stockItemId String?
  stockItem   StockItem? @relation(fields: [stockItemId], references: [id])

  partName  String
  quantity  Decimal  @db.Decimal(18, 2)
  unitCost  Decimal? @db.Decimal(18, 2)
  totalCost Decimal? @db.Decimal(18, 2)

  issuedMovementId String?
  issuedMovement   StockMovement? @relation(fields: [issuedMovementId], references: [id])

  createdAt DateTime @default(now())

  @@index([workshopJobId])
  @@index([stockItemId])
  @@index([issuedMovementId])
  @@map("fleet_workshop_parts")
}

model FleetWorkshopLabour {
  id String @id @default(uuid())

  workshopJobId String
  workshopJob   FleetWorkshopJob @relation(fields: [workshopJobId], references: [id], onDelete: Cascade)

  technicianName String
  labourHours    Decimal  @db.Decimal(18, 2)
  hourlyRate     Decimal? @db.Decimal(18, 2)
  labourCost     Decimal? @db.Decimal(18, 2)
  notes          String?

  createdAt DateTime @default(now())

  @@index([workshopJobId])
  @@map("fleet_workshop_labour")
}

model AssetImportBatch {
  id         String                 @id @default(uuid())
  batchNo    String                 @unique
  sourceType String
  fileName   String?
  status     AssetImportBatchStatus @default(DRAFT)

  totalRows   Int @default(0)
  validRows   Int @default(0)
  warningRows Int @default(0)
  errorRows   Int @default(0)
  postedRows  Int @default(0)

  createdBy  String?
  postedBy   String?
  postedAt   DateTime?
  notes      String?
  rawPayload Json?

  lines AssetImportLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssetImportLine {
  id      String           @id @default(uuid())
  batchId String
  batch   AssetImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  rowNumber     Int
  itemCode      String?
  itemName      String?
  itemType      String?
  category      String?
  unitOfMeasure String?
  locationCode  String?
  locationName  String?
  locationType  String?
  site          String?
  branch        String?
  department    String?

  quantityOnHand Decimal? @db.Decimal(18, 2)
  minimumLevel   Decimal? @db.Decimal(18, 2)
  reorderLevel   Decimal? @db.Decimal(18, 2)
  standardCost   Decimal? @db.Decimal(18, 2)

  scaffoldComponentNo String?
  componentType       String?
  conditionStatus     String?
  tagStatus           String?
  qrTagCode           String?

  status           AssetImportLineStatus @default(VALID)
  validationErrors Json?
  rawPayload       Json?

  legacySourceTable String?
  legacyRecordId    String?
  legacyCode        String?
  legacyPayload     Json?

  postedStockItemId String?
  postedLocationId  String?
  postedBalanceId   String?
  postedMovementId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId])
  @@index([itemCode])
  @@index([locationCode])
  @@index([qrTagCode])
  @@index([legacyCode])
}

model StoresRequisition {
  id                String   @id @default(uuid())
  requisitionNo     String   @unique

  title             String?
  description       String?
  reason            String?

  requestedBy       String?
  requestedByEmail  String?
  requesterRole     String?

  department        String?
  departmentId      String?
  site              String?
  branch            String?
  projectCode       String?

  status            String   @default("SUBMITTED")
  approvalRequestId String?

  totalValue        Decimal  @default(0)
  currency          String   @default("ZMW")

  submittedAt       DateTime @default(now())
  approvedBy        String?
  approvedAt        DateTime?
  rejectedBy        String?
  rejectedAt        DateTime?
  rejectionReason   String?

  payload           Json?

  lines             StoresRequisitionLine[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([requisitionNo])
  @@index([status])
  @@index([site])
  @@index([branch])
  @@index([department])
  @@index([approvalRequestId])
}

model StoresRequisitionLine {
  id             String   @id @default(uuid())
  requisitionId  String
  requisition    StoresRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)

  stockItemId    String?
  itemCode       String?
  itemName       String
  description    String?
  unitOfMeasure  String   @default("EA")

  quantity       Decimal  @default(1)
  unitCost       Decimal  @default(0)
  totalCost      Decimal  @default(0)

  notes          String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([requisitionId])
  @@index([stockItemId])
  @@index([itemCode])
}

