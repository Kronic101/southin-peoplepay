model StockLocation {
  id              String   @id @default(uuid())
  locationCode    String   @unique
  locationName    String
  locationType    String   @default("SITE_STORE")

  site            String?
  branch          String?
  department      String?

  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  balances        StockBalance[]
  movementsFrom   StockMovement[] @relation("StockMovementFromLocation")
  movementsTo     StockMovement[] @relation("StockMovementToLocation")
