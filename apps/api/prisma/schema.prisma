model StockItem {
  id              String        @id @default(uuid())
  itemCode        String        @unique
  itemName        String
  itemType        StockItemType
  category        String?
  description     String?

  unitOfMeasure   String        @default("EA")
  minimumLevel    Decimal?      @db.Decimal(18, 2)
  reorderLevel    Decimal?      @db.Decimal(18, 2)
  standardCost    Decimal?      @db.Decimal(18, 2)

  isSerialized    Boolean       @default(false)
  isQrTracked     Boolean       @default(false)
  isActive        Boolean       @default(true)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  balances        StockBalance[]
  movements       StockMovementLine[]
